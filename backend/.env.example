# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# SageMaker
SAGEMAKER_ENDPOINT_NAME=xtts-v2-endpoint

# S3
S3_BUCKET_NAME=ai-voice-platform-audio
S3_MODELS_BUCKET=ai-voice-platform-models

# DynamoDB
DYNAMODB_VOICES_TABLE=voice_models
DYNAMODB_PROJECTS_TABLE=projects
DYNAMODB_AUDIT_TABLE=audit_logs

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API Configuration
API_SECRET_KEY=your-secret-key-change-this
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_HOUR=1000

# Application
DEBUG=True
LOG_LEVEL=INFO

# Synthesis Mode (choose one):
# Option 1: Mock mode (for testing, no AWS costs)
USE_MOCK_SYNTHESIS=True
USE_AWS_POLLY=False

# Option 2: AWS Polly (real synthesis, fastest setup, ~$0.004 per request)
# USE_MOCK_SYNTHESIS=False
# USE_AWS_POLLY=True

# Option 3: SageMaker (best quality, requires endpoint deployment)
# USE_MOCK_SYNTHESIS=False
# USE_AWS_POLLY=False
